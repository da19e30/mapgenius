# Backend environment variables

# Database connection (asyncpg URL)
DATABASE_URL=postgresql+asyncpg://mvp_user:secretpassword@localhost:5432/mvp_db

# JWT secret – change in production!
JWT_SECRET_KEY=super-secret-key-change-me

# SMTP (optional – email notifications)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@mapgenius.com
